{% comment %}
  Bronx Nourish Access — Image-First Funnel App
  File: sections/bna-image-funnel-app.liquid
  Status: Draft/dev-ready. Do not publish without Jeremy approval.
{% endcomment %}

{% liquid
  assign poster_url = section.settings.poster_image_url
  if section.settings.poster_image != blank
    assign poster_url = section.settings.poster_image | image_url: width: 2400
  endif
%}

<section id="bna-image-{{ section.id }}" class="bna-image-app" style="--bna-green:{{ section.settings.green }};--bna-orange:{{ section.settings.orange }};--bna-gold:{{ section.settings.gold }};--bna-cream:{{ section.settings.cream }};--bna-text:{{ section.settings.text_color }};--bna-muted:{{ section.settings.muted_color }};--bna-poster:url('{{ poster_url }}');">
  <style>
    #bna-image-{{ section.id }}{background:var(--bna-cream);color:var(--bna-text);font-family:Arial,Helvetica,sans-serif}#bna-image-{{ section.id }} *{box-sizing:border-box}#bna-image-{{ section.id }} a{color:inherit}.bna-shell{max-width:1180px;margin:auto;padding:16px 16px 96px}.bna-artboard{position:relative;width:100%;aspect-ratio:1122/1402;min-height:720px;border-radius:34px;overflow:hidden;border:1px solid rgba(11,95,42,.16);box-shadow:0 18px 45px rgba(6,63,28,.12)}.bna-poster-bg{position:absolute;inset:0;background:linear-gradient(180deg,rgba(255,248,232,.16),rgba(255,248,232,.06)),var(--bna-poster) center/cover no-repeat}.bna-live{position:absolute;z-index:2}.bna-logo{top:2%;left:3%;display:flex;gap:10px;align-items:center;color:var(--bna-green);font-weight:950;text-transform:uppercase;line-height:.9}.bna-logo span,.bna-logo strong{display:block}.bna-logo strong{color:var(--bna-orange)}.bna-mark{width:54px;height:54px;border-radius:16px;background:var(--bna-green);color:white;display:grid;place-items:center;font-size:30px}.bna-nav{top:3.5%;left:50%;transform:translateX(-50%);display:flex;gap:20px;font-weight:900}.bna-nav a{text-decoration:none}.bna-lang{top:2.6%;right:3%;border:2px solid var(--bna-green);border-radius:999px;padding:10px 16px;background:#fffdf5;font-weight:950;text-decoration:none}.bna-hero{top:18%;left:50%;transform:translateX(-50%);width:min(82%,840px);text-align:center}.bna-pill{display:inline-flex;padding:8px 14px;border-radius:999px;background:rgba(255,248,232,.9);color:var(--bna-green);font-weight:950;text-transform:uppercase}.bna-h1{margin:14px 0;color:var(--bna-green);text-transform:uppercase;font-size:clamp(58px,13vw,146px);line-height:.76;letter-spacing:-.07em;font-weight:950;text-shadow:0 2px 0 rgba(255,255,255,.92)}.bna-h1 span{display:block;color:var(--bna-orange)}.bna-sub{margin:18px auto;padding:14px 18px;border-radius:20px;background:rgba(255,248,232,.9);font-size:clamp(18px,2.2vw,26px);line-height:1.25;font-weight:850}.bna-btn,.bna-submit{display:inline-flex;align-items:center;justify-content:center;min-height:58px;padding:16px 24px;border:0;border-radius:18px;text-decoration:none;cursor:pointer;font-weight:950;text-transform:uppercase;box-shadow:0 8px 0 rgba(6,63,28,.14)}.bna-primary{background:var(--bna-green);color:white;font-size:clamp(22px,3.3vw,38px);width:min(100%,720px);min-height:82px}.bna-actions{display:flex;justify-content:center;gap:12px;flex-wrap:wrap;margin-top:14px}.bna-secondary{background:var(--bna-orange);color:white}.bna-light{background:white;color:var(--bna-green)}.bna-card-row{left:3%;right:3%;bottom:4%;display:grid;grid-template-columns:repeat(3,1fr);gap:14px}.bna-action-card{display:flex;align-items:center;gap:13px;text-align:left;min-height:100px;padding:16px;border-radius:22px;color:white;text-decoration:none;box-shadow:0 10px 22px rgba(6,63,28,.12)}.bna-action-card.green{background:var(--bna-green)}.bna-action-card.orange{background:var(--bna-orange)}.bna-action-card.gold{background:var(--bna-gold)}.bna-action-card b{width:50px;height:50px;border-radius:16px;background:rgba(255,255,255,.22);display:grid;place-items:center;font-size:28px}.bna-action-card strong{display:block;text-transform:uppercase}.bna-action-card small{display:block;margin-top:4px;font-weight:700}.bna-panel{margin:22px 0;background:white;border:1px solid rgba(11,95,42,.16);border-radius:28px;padding:24px;box-shadow:0 14px 35px rgba(6,63,28,.08)}.bna-panel h2{margin:0 0 12px;color:var(--bna-green);text-transform:uppercase}.bna-steps{display:grid;grid-template-columns:repeat(4,1fr);gap:12px}.bna-step{background:#fffdf8;border:1px solid rgba(11,95,42,.14);border-radius:20px;padding:18px;text-align:center}.bna-step b{display:grid;place-items:center;width:34px;height:34px;margin:0 auto 8px;border-radius:999px;background:var(--bna-green);color:white}.bna-form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}.bna-field{display:flex;flex-direction:column;gap:6px}.bna-field.full{grid-column:1/-1}.bna-field label,.bna-consent{font-size:13px;font-weight:850}.bna-field input,.bna-field select,.bna-field textarea{min-height:50px;border:1px solid rgba(18,53,31,.22);border-radius:13px;padding:10px 12px;background:#fffdf8;color:var(--bna-text);font:inherit}.bna-consent{display:flex;gap:10px;margin:14px 0}.bna-submit{width:100%;background:var(--bna-orange);color:white;font-size:18px}.bna-fine{font-size:12px;line-height:1.5;color:var(--bna-muted);font-weight:650}.bna-mobile-sticky{position:fixed;left:0;right:0;bottom:0;z-index:9999;display:none;grid-template-columns:1fr 1fr;gap:8px;padding:10px;background:rgba(255,248,232,.96);border-top:1px solid rgba(11,95,42,.16)}.bna-mobile-sticky a{min-height:48px;border-radius:14px;display:grid;place-items:center;color:white;text-decoration:none;text-transform:uppercase;font-weight:950}.bna-mobile-sticky a:first-child{background:var(--bna-green)}.bna-mobile-sticky a:last-child{background:var(--bna-orange)}@media(max-width:900px){.bna-shell{padding:10px 10px 96px}.bna-artboard{aspect-ratio:600/750;min-height:640px;border-radius:24px}.bna-nav{display:none}.bna-logo{transform:scale(.82);transform-origin:left top}.bna-lang{font-size:13px;padding:9px 12px}.bna-hero{top:16%;width:88%}.bna-h1{font-size:clamp(54px,17vw,92px)}.bna-sub{font-size:16px;padding:10px 12px}.bna-actions{display:none}.bna-card-row{grid-template-columns:1fr;gap:8px;bottom:2.5%}.bna-action-card{min-height:66px;padding:10px}.bna-steps,.bna-form-grid{grid-template-columns:1fr}.bna-mobile-sticky{display:grid}}
  </style>

  <div class="bna-shell">
    <section class="bna-artboard" aria-label="Bronx Nourish Access food help funnel">
      <div class="bna-poster-bg" role="img" aria-label="Bronx Nourish Access poster image"></div>
      <div class="bna-live bna-logo"><div class="bna-mark">🌿</div><div><span>{{ section.settings.logo_line_1 }}</span><span>{{ section.settings.logo_line_2 }}</span><strong>{{ section.settings.logo_line_3 }}</strong></div></div>
      <nav class="bna-live bna-nav"><a href="#bna-image-{{ section.id }}">Home</a><a href="#bna-form-{{ section.id }}">Check Options</a><a href="#bna-how-{{ section.id }}">How It Works</a></nav>
      <a class="bna-live bna-lang" href="#bna-form-{{ section.id }}">{{ section.settings.language_button }}</a>
      <div class="bna-live bna-hero"><p class="bna-pill">{{ section.settings.eyebrow }}</p><h1 class="bna-h1">{{ section.settings.headline_line_1 }} <span>{{ section.settings.headline_line_2 }}</span></h1><p class="bna-sub">{{ section.settings.subheadline }}</p><a class="bna-btn bna-primary" href="#bna-form-{{ section.id }}">{{ section.settings.primary_cta }}</a><div class="bna-actions"><a class="bna-btn bna-secondary" href="#bna-form-{{ section.id }}">{{ section.settings.secondary_cta }}</a><a class="bna-btn bna-light" href="tel:{{ section.settings.phone_tel }}">{{ section.settings.phone_display }}</a></div></div>
      <div class="bna-live bna-card-row"><a class="bna-action-card green" href="#bna-form-{{ section.id }}"><b>🛒</b><span><strong>Get Food Help</strong><small>Find available food support options.</small></span></a><a class="bna-action-card orange" href="#bna-form-{{ section.id }}"><b>📋</b><span><strong>Check Options</strong><small>Answer a few quick questions.</small></span></a><a class="bna-action-card gold" href="tel:{{ section.settings.phone_tel }}"><b>☎</b><span><strong>Call for Help</strong><small>Use after phone number is verified.</small></span></a></div>
    </section>

    <section id="bna-how-{{ section.id }}" class="bna-panel"><h2>How It Works</h2><div class="bna-steps"><div class="bna-step"><b>1</b><strong>Tap & Check</strong><p>Start the quick check.</p></div><div class="bna-step"><b>2</b><strong>Answer Questions</strong><p>Submit basic routing information.</p></div><div class="bna-step"><b>3</b><strong>Review Options</strong><p>A support path can be identified.</p></div><div class="bna-step"><b>4</b><strong>Get Connected</strong><p>Receive next-step information.</p></div></div></section>

    <section id="bna-form-{{ section.id }}" class="bna-panel"><h2>{{ section.settings.form_heading }}</h2><p>{{ section.settings.form_subheading }}</p>{% form 'contact', id: 'bna_image_contact_form' %}{% if form.posted_successfully? %}<p style="color:var(--bna-green);font-weight:950">Thank you. Your request was submitted.</p>{% endif %}{{ form.errors | default_errors }}<input type="hidden" name="contact[Page Source]" value="Bronx Nourish Access /pages/food-help"><input type="hidden" id="bna_utm_source_{{ section.id }}" name="contact[UTM Source]"><input type="hidden" id="bna_utm_medium_{{ section.id }}" name="contact[UTM Medium]"><input type="hidden" id="bna_utm_campaign_{{ section.id }}" name="contact[UTM Campaign]"><div class="bna-form-grid"><div class="bna-field"><label>First name *</label><input name="contact[First Name]" autocomplete="given-name" required></div><div class="bna-field"><label>Phone *</label><input type="tel" name="contact[Phone]" autocomplete="tel" required></div><div class="bna-field"><label>ZIP code *</label><input name="contact[ZIP Code]" inputmode="numeric" autocomplete="postal-code" required></div><div class="bna-field"><label>Language</label><select name="contact[Preferred Language]"><option>English</option><option>Spanish</option><option>Other</option></select></div><div class="bna-field full"><label>Medicaid / health plan status *</label><select name="contact[Medicaid or Health Plan Status]" required><option value="">Select one</option><option>I have Medicaid</option><option>I have a health plan but I am not sure which one</option><option>I do not have Medicaid</option><option>I am not sure</option></select></div><div class="bna-field full"><label>Do you need help getting groceries or cooking? *</label><select name="contact[Needs Grocery or Cooking Help]" required><option value="">Select one</option><option>Yes</option><option>No</option><option>Not sure</option></select></div><div class="bna-field full"><label>Best callback time</label><select name="contact[Best Callback Time]"><option>Morning</option><option>Afternoon</option><option>Evening</option><option>Anytime</option></select></div></div><label class="bna-consent"><input type="checkbox" name="contact[Consent to Contact]" value="Yes" required><span>I agree to be contacted about available food help options using the information I submit.</span></label><button class="bna-submit" type="submit">{{ section.settings.submit_button }}</button><p class="bna-fine">Do not submit SSNs, Medicaid IDs, case numbers, immigration information, diagnoses, or sensitive documents through this form.</p>{% endform %}</section>

    <footer class="bna-panel bna-fine">Bronx Nourish Access is an information and routing page. Submitting this form does not guarantee eligibility, approval, enrollment, delivery, or benefits. Program availability may vary. No payment is required to check available options.</footer>
  </div>
  {% if section.settings.show_mobile_sticky %}<div class="bna-mobile-sticky"><a href="#bna-form-{{ section.id }}">Check Options</a><a href="tel:{{ section.settings.phone_tel }}">Call</a></div>{% endif %}
  <script>(function(){var p=new URLSearchParams(window.location.search);['source','medium','campaign'].forEach(function(k){var el=document.getElementById('bna_utm_'+k+'_{{ section.id }}');var v=p.get('utm_'+k)||localStorage.getItem('bna_utm_'+k)||'';if(p.get('utm_'+k)){localStorage.setItem('bna_utm_'+k,p.get('utm_'+k));}if(el){el.value=v;}});})();</script>
</section>
{% schema %}{"name":"BNA Image Funnel App","tag":"section","class":"section-bna-image-funnel-app","settings":[{"type":"image_picker","id":"poster_image","label":"Full landing page image"},{"type":"text","id":"poster_image_url","label":"Fallback image URL","default":"https://cdn.shopify.com/s/files/1/0771/5759/7355/files/bronx-nourish-access-funnel-hero.jpg"},{"type":"text","id":"logo_line_1","label":"Logo line 1","default":"Bronx"},{"type":"text","id":"logo_line_2","label":"Logo line 2","default":"Nourish"},{"type":"text","id":"logo_line_3","label":"Logo line 3","default":"Access"},{"type":"text","id":"language_button","label":"Language button","default":"Español"},{"type":"text","id":"eyebrow","label":"Eyebrow","default":"Supporting Bronx families"},{"type":"text","id":"headline_line_1","label":"Headline line 1","default":"Food Help"},{"type":"text","id":"headline_line_2","label":"Headline line 2","default":"Access"},{"type":"textarea","id":"subheadline","label":"Subheadline","default":"You may qualify for free or low-cost food support through available community, health-plan, nonprofit, or government-supported programs."},{"type":"text","id":"primary_cta","label":"Primary CTA","default":"Tap Here to Check Options"},{"type":"text","id":"secondary_cta","label":"Secondary CTA","default":"Request a Callback"},{"type":"text","id":"phone_display","label":"Phone display","default":"Call for Help"},{"type":"text","id":"phone_tel","label":"Phone tel link","default":"+10000000000"},{"type":"text","id":"form_heading","label":"Form heading","default":"Start Your Food Help Check"},{"type":"textarea","id":"form_subheading","label":"Form subheading","default":"Answer a few quick questions. A team member may follow up with available next steps."},{"type":"text","id":"submit_button","label":"Submit button","default":"Submit Food Help Request"},{"type":"checkbox","id":"show_mobile_sticky","label":"Show mobile sticky CTA bar","default":true},{"type":"color","id":"green","label":"Green","default":"#0b5f2a"},{"type":"color","id":"orange","label":"Orange","default":"#e95713"},{"type":"color","id":"gold","label":"Gold","default":"#f4b321"},{"type":"color","id":"cream","label":"Cream","default":"#fff8e8"},{"type":"color","id":"text_color","label":"Text","default":"#12351f"},{"type":"color","id":"muted_color","label":"Muted","default":"#46614f"}],"presets":[{"name":"BNA Image Funnel App"}]}{% endschema %}
